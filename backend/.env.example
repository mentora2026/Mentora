# ──────────────────────────────────────────────────────────────
# Mentora Backend — Environment Configuration
# Copy this file to .env and fill in your real values.
# ──────────────────────────────────────────────────────────────

# Application
APP_NAME="Adaptive Psychological Monitoring Platform"
ENVIRONMENT=development
DEBUG=true
SEED_ON_STARTUP=false

# Security
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate-a-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# Local Docker Compose:  postgresql+psycopg2://postgres:postgres@db:5432/psych_platform
# Supabase / remote:     postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/psych_platform

# Firebase Cloud Messaging (optional, for push notifications)
FCM_SERVER_KEY=

# AI / LLM (set ENABLE_LLM=true and provide LLM_API_KEY to activate)
ENABLE_LLM=false
LLM_PROVIDER=nvidia
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=deepseek-ai/deepseek-v4-pro
LLM_API_KEY=

# Sentiment Analysis (set ENABLE_HF_SENTIMENT=true once model is downloaded)
HF_SENTIMENT_MODEL=CAMeL-Lab/bert-base-arabic-camelbert-da-sentiment
ENABLE_HF_SENTIMENT=false

# Admin Seed — password for the default admin user created by `python -m app.seed`
ADMIN_SEED_PASSWORD=ChangeMe123!
