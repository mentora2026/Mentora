# Application
APP_NAME="Adaptive Psychological Monitoring Platform"
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/psych_platform

# Firebase Cloud Messaging (used in later steps)
FCM_SERVER_KEY=

# AI / LLM (used in Step 3)
HF_SENTIMENT_MODEL=CAMeL-Lab/bert-base-arabic-camelbert-da-sentiment
LLM_API_KEY=
